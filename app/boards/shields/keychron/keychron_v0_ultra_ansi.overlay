&timer2 {
    status = "okay";
    prescaler = <1>;
};
&timer3 {
    status = "okay";
    prescaler = <1>;
};
&timer8 {
    status = "okay";
};

&timer9 {
    status = "okay";
};

&corewdt {
    // status = "disabled";
	status = "okay";
    initial-timeout-ms = <5000>;
};
&aonwdt {
    // status = "okay";
    status = "disabled";
    initial-timeout-ms = <5000>;
};
/ {
	aliases {
        // watchdog = &aonwdt;
		watchdog = &corewdt;
	};
    
};

&adc {
    pinctrl-0 = <&adc_default>;
    pinctrl-1 = <&adc_sleep>;
    pinctrl-names = "default","sleep";
    #address-cells = <1>;
    #size-cells = <0>;
    status = "okay";
    is-bypass-mode= <0x08>;
    channel@8 {
        reg = <8>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <12>;
    };
};	
/ {
    chosen {
        // zmk,kscan = &kscan;
        zmk,kscan = &kscan_comp;
        zmk,matrix-transform = &default_transform;
        zmk,battery = &vbatt;
        //zmk,backlight = &backlight;
    };
    kscan_comp: kscan {
        compatible = "zmk,kscan-composite";
        rows = <7>;
        columns = <5>;
        // Include the direct GPIO driver...
        // make sure direct init first!
        direct {
            kscan = <&kscan1>;
            row-offset = <6>; // ...and shift it to not overlap
        };
        // Include the matrix driver
        matrix {
            kscan = <&kscan0>;
            // kscan = <&kscan>;
        };


        // status = "disabled";
    };
    kscan0: kscan_matrix {
        compatible = "zmk,kscan-gpio-matrix";

        diode-direction = "row2col";
        debounce-scan-period-ms =<1>;
        debounce-press-ms =<0>;
        debounce-release-ms=<50>;
 
        row-gpios
            = <&gpiob 20 (GPIO_ACTIVE_HIGH |GPIO_PULL_UP )>    //r0 P5_7
            , <&gpiob  0 (GPIO_ACTIVE_HIGH |GPIO_PULL_UP)>    //r1 P3_3
            , <&gpiob  1 (GPIO_ACTIVE_HIGH |GPIO_PULL_UP)>    //r2 P3_4
            , <&gpiob  2 (GPIO_ACTIVE_HIGH |GPIO_PULL_UP)>    //r3 P3_5
            , <&gpiob  3 (GPIO_ACTIVE_HIGH |GPIO_PULL_UP)>    //r4 P3_6
            , <&gpiob  4 (GPIO_ACTIVE_HIGH |GPIO_PULL_UP)>    //r5 P3_7
            ;
        col-gpios
            = <&gpioa 9  (GPIO_ACTIVE_HIGH|GPIO_PULL_DOWN)>  //c0 P1_1   
            , <&gpioa 8  (GPIO_ACTIVE_HIGH|GPIO_PULL_DOWN)>  //c1 P1_0      
            , <&gpioa 4  (GPIO_ACTIVE_HIGH|GPIO_PULL_DOWN)>  //c2 P0_4    
            , <&gpioa 10  (GPIO_ACTIVE_HIGH|GPIO_PULL_DOWN)>  //c3 P1_2   
            , <&gpioa 5  (GPIO_ACTIVE_HIGH|GPIO_PULL_DOWN)>  //c4 P0_5
           
            
            ;
        pinctrl-0 = <&gpio_default>;
        pinctrl-1 = <&gpio_sleep>;
        pinctrl-names = "default","sleep";

        // status ="disabled";
    };
    kscan1:kscan_direct {
        compatible = "zmk,kscan-gpio-direct";
        input-gpios
        = <&gpioa 17  (GPIO_ACTIVE_LOW )>  //bt        //32k_xi
        , <&gpioa 18  (GPIO_ACTIVE_LOW )>  //24g       //32k_xo
        , <&gpiob 19  (GPIO_ACTIVE_LOW )>  //usb det   //P5_6
        , <&gpioa 28  (GPIO_ACTIVE_LOW )>  //charging  //p2_7
        ;
        // toggle-mode;
        debounce-scan-period-ms=<20>;
        debounce-release-ms=<20>;
        pinctrl-0 = <&gpio_direct_default>;
        pinctrl-1 = <&gpio_direct_sleep>;
        pinctrl-names = "default","sleep";
    };
    // mode_monitor: mode_monitor {
    //     compatible = "zmk,mode-monitor-pin";
    //     ble-gpios = <&gpioa 9 (GPIO_ACTIVE_HIGH )>;
    //     ppt-gpios = <&gpioa 8 (GPIO_ACTIVE_HIGH )>;
    //     detect-usb-gpios = <&gpioa 24 (GPIO_ACTIVE_HIGH )>;
    //     win2mac-gpios = <&gpioa 31 (GPIO_ACTIVE_HIGH )>;
    // };
    vbatt: vbatt {
        compatible = "zmk,battery-voltage-divider";
        io-channels = <&adc 3>;
        output-ohms = <220000>;
        full-ohms = <(1000000 + 220000)>;
    };


    // led_rgb:led_rgb  {
    //     compatible = "pwm-leds";
    //     status =  "disabled";//"okay";
    //     pwm_led_0 {
    //         pwms = <&pwm2 0 10000 PWM_POLARITY_INVERTED>;
    //     };
    //     pwm_led_1 {
    //         pwms = <&pwm3 0 10000 PWM_POLARITY_INVERTED>;
    //     };
    //     pwm_led_2 {
    //         pwms = <&pwm4 0 10000 PWM_POLARITY_INVERTED>;
    //     };
    // };

    led_red: led_red{
        compatible = "gpio-leds";
        status ="okay";
        pwr-gpios {
            gpios= <&gpioa 27 GPIO_ACTIVE_HIGH>;  //chgled p2_6
        };
        
    };

    gpio_ctrls {
        compatible = "gpio-leds";
        usb_det:usb_det {
            gpios= <&gpiob 19 GPIO_ACTIVE_LOW>;  //p5_6
        };
        debug_io:debug_io {
            gpios= <&gpioa 28 GPIO_ACTIVE_LOW>;  //p2_7
        };
    };
    
	ppt: ppt {
		compatible = "zmk,ppt-node";
		enh-timers = <&timer8 &timer9>;
		status = "okay";
	};

    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        rows = <7>;
        columns = <5>;
        map = <
            //enc        //f1        //f2       //f3          //f4
            RC(0,0)     RC(0,1)     RC(0,2)     RC(0,3)    RC(0,4) 
             //m1       //num        // /         // *       // -  
            RC(1,0)     RC(1,1)     RC(1,2)     RC(1,3)    RC(1,4) 
            //m2         //7         //8        // 9        // +   
            RC(2,0)     RC(2,1)     RC(2,2)     RC(2,3)    RC(2,4) 
            //m3        //4         //5         //6             
            RC(3,0)     RC(3,1)     RC(3,2)     RC(3,3)     
             //m4       //1          //2         //3       //enter  
            RC(4,0)     RC(4,1)     RC(4,2)     RC(4,3)    RC(4,4)  
            //m5                     //0         //.
            RC(5,0)                 RC(5,2)     RC(5,3)   
            //bt        //24g       //usb       //ch          
            RC(6,0)     RC(6,1)     RC(6,2)     RC(6,3)        
        >;
    };


    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        status = "okay";
        sensors = <&aon_qdec>;
        triggers-per-rotation = <10>;
    };
 };



&pinctrl {
    adc_default: adc_default {
        group1 {
             psels = <RTL87X2G_PSEL(SW_MODE, P2_3, DIR_IN, DRV_LOW, PULL_NONE)>;
        };
    };

    adc_sleep: adc_sleep {
        group1 {
             psels = <RTL87X2G_PSEL(SW_MODE, P2_3, DIR_IN, DRV_LOW, PULL_DOWN)>;
        };
    };
    
    
    pwm2_default: pwm2_default {
        group1 {
            psels = <RTL87X2G_PSEL(TIMER_PWM2, P2_4,DIR_OUT, DRV_LOW, PULL_DOWN)>;
        };
    };
    pwm3_default: pwm3_default {
        group1 {
            psels = <RTL87X2G_PSEL(TIMER_PWM3, P2_3,DIR_OUT, DRV_LOW, PULL_DOWN)>;
        };
    };
    pwm4_default: pwm4_default {
        group1 {
            psels = <RTL87X2G_PSEL(TIMER_PWM4, P2_4,DIR_OUT, DRV_LOW, PULL_DOWN)>;
        };
    };
    pwm4_sleep: pwm4_sleep {
        group1 {
            psels = <RTL87X2G_PSEL(SW_MODE, P2_4,DIR_IN, DRV_LOW, PULL_DOWN)>;
        };
    };
    uart2_default: uart2_default {
        group1 {
            psels = <RTL87X2G_PSEL(UART2_TX, P3_0, DIR_OUT, DRV_HIGH, PULL_UP)>,
            <RTL87X2G_PSEL(UART2_RX, P3_1, DIR_IN, DRV_HIGH, PULL_UP)>;
        };
    };
    uart2_sleep: uart2_sleep {
        group1 {
            psels = <RTL87X2G_PSEL(SW_MODE, P3_0, DIR_IN, DRV_HIGH, PULL_UP)>,
            <RTL87X2G_PSEL(SW_MODE, P3_1, DIR_IN, DRV_HIGH, PULL_UP)>;
        };
    };
    gpio_default: gpio_default {
        group1 {
            psels = 
             <RTL87X2G_PSEL(DWGPIO, P5_7, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(DWGPIO, P3_3, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(DWGPIO, P3_4, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(DWGPIO, P3_5, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(DWGPIO, P3_6, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(DWGPIO, P3_7, DIR_OUT, DRV_HIGH, PULL_UP)>;
             bias-pull-strong;
        };
        group2 {
            psels = 
             <RTL87X2G_PSEL(DWGPIO, P1_1, DIR_IN, DRV_LOW, PULL_DOWN)>,
             <RTL87X2G_PSEL(DWGPIO, P1_0, DIR_IN, DRV_LOW, PULL_DOWN)>,
             <RTL87X2G_PSEL(DWGPIO, P0_4, DIR_IN, DRV_LOW, PULL_DOWN)>,
             <RTL87X2G_PSEL(DWGPIO, P1_2, DIR_IN, DRV_LOW, PULL_DOWN)>,
             <RTL87X2G_PSEL(DWGPIO, P0_5, DIR_IN, DRV_LOW, PULL_DOWN)>;
           
             bias-pull-strong;
        };
    };
    gpio_sleep: gpio_sleep {
        group1 {
            psels = 
             <RTL87X2G_PSEL(SW_MODE, P5_7, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(SW_MODE, P3_3, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(SW_MODE, P3_4, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(SW_MODE, P3_5, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(SW_MODE, P3_6, DIR_OUT, DRV_HIGH, PULL_UP)>,
             <RTL87X2G_PSEL(SW_MODE, P3_7, DIR_OUT, DRV_HIGH, PULL_UP)>;
        };
        group2 {
            psels = 
             <RTL87X2G_PSEL(SW_MODE, P1_1, DIR_IN, DRV_LOW, PULL_DOWN)>,
             <RTL87X2G_PSEL(SW_MODE, P1_0, DIR_IN, DRV_LOW, PULL_DOWN)>,
             <RTL87X2G_PSEL(SW_MODE, P0_4, DIR_IN, DRV_LOW, PULL_DOWN)>,
             <RTL87X2G_PSEL(SW_MODE, P1_2, DIR_IN, DRV_LOW, PULL_DOWN)>,
             <RTL87X2G_PSEL(SW_MODE, P0_5, DIR_IN, DRV_LOW, PULL_DOWN)>;
            
             wakeup-high;
        };
    };
    qdec_default: qdec_default {
        group1 {
            psels = <RTL87X2G_PSEL(QDPH0_IN_P9_0_P9_1, P9_0, DIR_IN, DRV_LOW, PULL_UP)>,
             <RTL87X2G_PSEL(QDPH0_IN_P9_0_P9_1, P9_1, DIR_IN, DRV_LOW, PULL_UP)>;
             wakeup-low;
        };
    };
    qdec_sleep: qdec_sleep {
        group1 {
            psels = <RTL87X2G_PSEL(SW_MODE, P9_0, DIR_IN, DRV_HIGH, PULL_NONE)>,
             <RTL87X2G_PSEL(SW_MODE, P9_1, DIR_IN, DRV_HIGH, PULL_NONE)>;

        };
    };
    gpio_direct_default:gpio_direct_default{
        group1 {
            psels = 
             
             <RTL87X2G_PSEL(DWGPIO, XI32K, DIR_IN, DRV_HIGH, PULL_NONE)>,
             <RTL87X2G_PSEL(DWGPIO, XO32K, DIR_IN, DRV_HIGH, PULL_NONE)>,
             <RTL87X2G_PSEL(DWGPIO, P5_6, DIR_IN, DRV_HIGH, PULL_NONE)>,
             <RTL87X2G_PSEL(DWGPIO, P2_7, DIR_IN, DRV_HIGH, PULL_UP)>;//charge pin leak current ,has to pull up！
        };
    };
    gpio_direct_sleep:gpio_direct_sleep{
        group1 {
            psels = 
             <RTL87X2G_PSEL(SW_MODE, XI32K, DIR_IN, DRV_HIGH, PULL_NONE)>,
             <RTL87X2G_PSEL(SW_MODE, XO32K, DIR_IN, DRV_HIGH, PULL_NONE)>,
             <RTL87X2G_PSEL(SW_MODE, P5_6, DIR_IN, DRV_HIGH, PULL_NONE)>,
             <RTL87X2G_PSEL(SW_MODE, P2_7, DIR_IN, DRV_HIGH, PULL_UP)>;//charge pin leak current ,has to pull up！
            //  bias-pull-strong;
        };
    };
};

&aon_qdec {
    status = "okay";
    // status = "disabled";
    pinctrl-0 = <&qdec_default>;
    pinctrl-1 = <&qdec_sleep>;
    pinctrl-names = "default","sleep";
    counts-per-revolution =<4>;
};

