#include <dt-bindings/zmk/ckled2001.h>

/ {
    chosen {
        
        zmk,underglow = &led_strip;
    };
    led_strip: led-strip-composite {
        compatible = "zmk,led-strip-composite";
        chain-length = <87>;
        strip0 {
            led-strip = <&led_strip_0>;
        };
        strip1 {
            led-strip = <&led_strip_1>;
        };
    };

    

};
// dma is optional
&dma0 {
    status = "okay";
};
 
&spi0 {
    status = "okay";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default","sleep";
    cs-gpios=
        <&gpioa  5 GPIO_ACTIVE_LOW>,  //cs0 p0_5
        <&gpiob  8 GPIO_ACTIVE_LOW>;  //cs1 p4_3
        
    // dma is optional
	dmas = <&dma0 6 17 0xa>, <&dma0 5 16 0x10021>;
	dma-names = "rx", "tx";

        led_strip_0: ckled2001@0 {
            compatible = "zmk,spi,ckled2001";
            reg = <0>;
            spi-max-frequency = <4000000>;
            chain-length = <50>; //16+17+17
            map = <
            /* ROW 0 */
            /*   R        G        B */
            // CK(6,15) CK(8,15) CK(7,15)
            CK(6,14) CK(8,14) CK(7,14)
            CK(6,13) CK(8,13) CK(7,13)
            CK(6,12) CK(8,12) CK(7,12)
            CK(6,11) CK(8,11) CK(7,11)
            CK(6,10) CK(8,10) CK(7,10)
            CK(6, 9) CK(8, 9) CK(7, 9)
            CK(6, 8) CK(8, 8) CK(7, 8)
            CK(6, 7) CK(8, 7) CK(7, 7)
            CK(6, 6) CK(8, 6) CK(7, 6)
            CK(6, 5) CK(8, 5) CK(7, 5)
            CK(6, 4) CK(8, 4) CK(7, 4)
            CK(6, 3) CK(8, 3) CK(7, 3)
            CK(6, 2) CK(8, 2) CK(7, 2)
            // CK(6, 1) CK(8, 1) CK(7, 1)            
            CK(6, 0) CK(8, 0) CK(7, 0)

            CK(3,5) CK(5,5) CK(4,5)
            CK(3,4) CK(5,4) CK(4,4)

            /* ROW 1 */
            /*   R        G        B */
            // CK(0,15) CK(2,15) CK(1,15)
            CK(0,14) CK(2,14) CK(1,14)
            CK(0,13) CK(2,13) CK(1,13)
            CK(0,12) CK(2,12) CK(1,12)
            CK(0,11) CK(2,11) CK(1,11)
            CK(0,10) CK(2,10) CK(1,10)
            CK(0, 9) CK(2, 9) CK(1, 9)
            CK(0, 8) CK(2, 8) CK(1, 8)
            CK(0, 7) CK(2, 7) CK(1, 7)
            CK(0, 6) CK(2, 6) CK(1, 6)
            CK(0, 5) CK(2, 5) CK(1, 5)
            CK(0, 4) CK(2, 4) CK(1, 4)
            CK(0, 3) CK(2, 3) CK(1, 3)
            CK(0, 2) CK(2, 2) CK(1, 2)
            CK(0, 1) CK(2, 1) CK(1, 1)
            CK(0, 0) CK(2, 0) CK(1, 0)

            CK(3,3) CK(5,3) CK(4,3)
            CK(3,2) CK(5,2) CK(4,2)

            /* ROW 2 */
            /*   R        G        B */
            // CK(9,15) CK(11,15) CK(10,15)
            CK(9,14) CK(11,14) CK(10,14)
            CK(9,13) CK(11,13) CK(10,13)
            CK(9,12) CK(11,12) CK(10,12)
            CK(9,11) CK(11,11) CK(10,11)
            CK(9,10) CK(11,10) CK(10,10)
            CK(9, 9) CK(11, 9) CK(10, 9)
            CK(9, 8) CK(11, 8) CK(10, 8)
            CK(9, 7) CK(11, 7) CK(10, 7)            
            CK(9, 6) CK(11, 6) CK(10, 6)
            CK(9, 5) CK(11, 5) CK(10, 5)
            CK(9, 4) CK(11, 4) CK(10, 4)
            CK(9, 3) CK(11, 3) CK(10, 3)
            CK(9, 2) CK(11, 2) CK(10, 2)
            CK(9, 1) CK(11, 1) CK(10, 1)
            CK(9, 0) CK(11, 0) CK(10, 0)       
            
            CK(3,1) CK(5,1) CK(4,1)
            CK(3,0) CK(5,0) CK(4,0)

            >;
            current_tune =
            // <0x60 0xC4 0xC4 0x60 0xC4 0xC4 0x60 0xC4 0xC4 0x60 0xC4 0xC4>;
            //    <0x25 0x4c 0x4c 0x25 0x4c 0x4c 0x25 0x4c 0x4c 0x25 0x4c 0x4c >;
            <0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 >;
            pwrctrl-gpios =<&gpioa 6 GPIO_ACTIVE_HIGH>;  //P0_6
            pinctrl-0 = <&ckled_default>;
            pinctrl-1 = <&ckled_sleep>;
            pinctrl-names = "default","sleep";
    };
    led_strip_1: ckled2001@1 {
            compatible = "zmk,spi,ckled2001";
            reg = <1>;
            spi-max-frequency = <4000000>;
            chain-length = <37>;//13 +13 +11
            map = <
            /* ROW 3 */
            /*   R        G        B */
            // CK(0,15) CK(2,15) CK(1,15)
            CK(0,14) CK(2,14) CK(1,14)
            CK(0,13) CK(2,13) CK(1,13)
            CK(0,12) CK(2,12) CK(1,12)
            CK(0,11) CK(2,11) CK(1,11)
            CK(0,10) CK(2,10) CK(1,10)
            CK(0, 9) CK(2, 9) CK(1, 9)
            CK(0, 8) CK(2, 8) CK(1, 8)
            CK(0, 7) CK(2, 7) CK(1, 7)
            CK(0, 6) CK(2, 6) CK(1, 6)
            CK(0, 5) CK(2, 5) CK(1, 5)
            CK(0, 4) CK(2, 4) CK(1, 4)
            CK(0, 3) CK(2, 3) CK(1, 3) 
            // CK(0, 2) CK(2, 2) CK(1, 2) 
            CK(0, 1) CK(2, 1) CK(1, 1) 
            // CK(0, 0) CK(2, 0) CK(1, 0) 

            /* ROW 4 */
            /*   R        G        B */
            // CK(6,15) CK(8,15) CK(7,15)
            CK(6,14) CK(8,14) CK(7,14)
            // CK(6,13) CK(8,13) CK(7,13)
            CK(6,12) CK(8,12) CK(7,12)
            CK(6,11) CK(8,11) CK(7,11)
            CK(6,10) CK(8,10) CK(7,10)
            CK(6, 9) CK(8, 9) CK(7, 9)
            CK(6, 8) CK(8, 8) CK(7, 8)
            CK(6, 7) CK(8, 7) CK(7, 7)
            CK(6, 6) CK(8, 6) CK(7, 6)
            CK(6, 5) CK(8, 5) CK(7, 5)
            CK(6, 4) CK(8, 4) CK(7, 4)
            CK(6, 3) CK(8, 3) CK(7, 3)
            // CK(6, 2) CK(8, 2) CK(7, 2)
            CK(6, 1) CK(8, 1) CK(7, 1)  
            CK(6, 0) CK(8, 0) CK(7, 0)

            /* ROW 5 */
            /*   R        G        B */
            // CK(3,15) CK(5,15) CK(4,15)
            CK(3,14) CK(5,14) CK(4,14)
            CK(3,13) CK(5,13) CK(4,13)
            CK(3,12) CK(5,12) CK(4,12)
            // CK(3,11) CK(5,11) CK(4,11)
            // CK(3,10) CK(5,10) CK(4,10)
            // CK(3, 9) CK(5, 9) CK(4, 9)
            CK(3, 8) CK(5, 8) CK(4, 8)
            // CK(3, 7) CK(5, 7) CK(4, 7)
            CK(3, 6) CK(5, 6) CK(4, 6)
            CK(3, 5) CK(5, 5) CK(4, 5)
            CK(3, 4) CK(5, 4) CK(4, 4)
            CK(3, 3) CK(5, 3) CK(4, 3)
            CK(3, 2) CK(5, 2) CK(4, 2)
            CK(3, 1) CK(5, 1) CK(4, 1)
            CK(3, 0) CK(5, 0) CK(4, 0)

            

            >;
            current_tune =
            // <0x60 0xC4 0xC4 0x60 0xC4 0xC4 0x60 0xC4 0xC4 0x60 0xC4 0xC4>;
            // <0x25 0x4c 0x4c 0x25 0x4c 0x4c 0x25 0x4c 0x4c 0x25 0x4c 0x4c >;
            <0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 0x38 >;
            pwrctrl-gpios =<&gpioa  6 (GPIO_ACTIVE_HIGH|GPIO_PULL_UP)>;//P0_6
            pinctrl-0 = <&ckled_default>;
            pinctrl-1 = <&ckled_sleep>;
            pinctrl-names = "default","sleep";
    };

};

&pinctrl {


    spi0_default:spi0_default{
        group1 {
            psels = <RTL87X2G_PSEL(SPI0_CLK_MASTER, P4_0, DIR_OUT, DRV_HIGH, PULL_UP)>,
            <RTL87X2G_PSEL(SPI0_MO_MASTER, P4_2, DIR_OUT, DRV_HIGH, PULL_UP)>,
            <RTL87X2G_PSEL(SPI0_CSN_0_MASTER, P0_5, DIR_OUT, DRV_HIGH, PULL_UP)>,
            <RTL87X2G_PSEL(SPI0_CSN_1_MASTER, P4_3, DIR_OUT, DRV_HIGH, PULL_UP)>;
        };
    };
    spi0_sleep:spi0_sleep{
        group1 {
            psels = <RTL87X2G_PSEL(SW_MODE, P4_0, DIR_IN, DRV_LOW, PULL_DOWN)>,
            <RTL87X2G_PSEL(SW_MODE, P4_2, DIR_IN, DRV_LOW, PULL_DOWN)>,
            <RTL87X2G_PSEL(SW_MODE, P0_5, DIR_IN, DRV_LOW, PULL_DOWN)>,
            <RTL87X2G_PSEL(SW_MODE, P4_3, DIR_IN, DRV_LOW, PULL_DOWN)>;
        };
    };
    ckled_default:ckled_default {
        group1 {
            psels =
            <RTL87X2G_PSEL(DWGPIO, P0_6, DIR_OUT, DRV_HIGH, PULL_UP)>;
            
        };
    };
    ckled_sleep:ckled_sleep {
        group1 {
            psels =
            <RTL87X2G_PSEL(SW_MODE, P0_6, DIR_IN, DRV_LOW, PULL_DOWN)>;
            
        };
    };
};