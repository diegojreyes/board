  "menus": [
    {
      "label": "Lighting",
      "content": [
        {
          "label": "Backlight",
          "content": [
            {
              "label": "Brightness",
              "type": "range",
              "options": [0, 255],
              "content": ["id_qmk_rgb_matrix_brightness", 3, 1]
            },
            {
              "label": "Effect",
              "type": "dropdown",
              "content": ["id_qmk_rgb_matrix_effect", 3, 2],
              "options": [
                ["None", 0],
                ["Solid Color", 1],
                ["Breathing", 2],
                ["Band Spiral Val", 3],
                ["Cycle All", 4],
                ["Cycle Left Right", 5],
                ["Cycle Up Down", 6],
                ["Rainbow Moving Chevron", 7],
                ["Cycle Out In", 8],
